# Client360 — example environment configuration (E1.1 scaffold).
#
# SAFE TO COMMIT: this file contains NO secrets, credentials, tokens, or PII.
# Copy the values you need into app/.env (which is gitignored) for local runs.
# The authoritative variable list lives in app/config.py and the deployment runbook.
#
# Values below are placeholders or safe development defaults only.

# "production" enables strict mode (SESSION_SECRET required, HTTPS-only cookies).
CLIENT360_ENVIRONMENT=development

# PostgreSQL connection string. No built-in default — must be set for the app to
# start. Localhost dev value shown; the test suite uses a disposable *_test DB.
DATABASE_URL=postgresql://localhost/client360

# Session cookie signing key. REQUIRED in production (startup fails without it).
# Leave EMPTY in development to use the marked insecure development fallback.
SESSION_SECRET=

# Fernet key encrypting Microsoft OAuth token caches. REQUIRED only for
# Microsoft 365 sync; leave EMPTY to disable that sync. Back it up separately
# from the database. Do NOT commit a real key.
MICROSOFT_TOKEN_KEY=

# --- Observability (E1.5) ----------------------------------------------------
# Application logging for the `client360` logger namespace (does not affect
# uvicorn's own logs). Safe defaults applied in code if unset.
#   LOG_LEVEL  : DEBUG | INFO | WARNING | ERROR | CRITICAL   (default INFO)
#   LOG_FORMAT : plain | json                                (default plain)
LOG_LEVEL=INFO
LOG_FORMAT=plain

# --- Transactional outbox dispatcher (E1.6 / F1.3) ---------------------------
# The outbox mechanism always ships; the background DISPATCHER is opt-in and OFF
# by default (nothing publishes events yet, so enabling it changes nothing until
# producers/subscribers exist).
#   OUTBOX_DISPATCHER_ENABLED       : true|false                 (default false)
#   OUTBOX_DISPATCH_INTERVAL_SECONDS: poll cadence, min 5        (default 30)
OUTBOX_DISPATCHER_ENABLED=false
OUTBOX_DISPATCH_INTERVAL_SECONDS=30

# --- Optional operational tunables (safe defaults applied in code if unset) ---
BENEFITS_NEW_HIRE_WINDOW_DAYS=30
BENEFITS_RENEWAL_WARNING_DAYS=60
BENEFITS_OE_WARNING_DAYS=7
BENEFITS_SCAN_INTERVAL_MINUTES=30
INSURANCE_SCAN_INTERVAL_MINUTES=30
